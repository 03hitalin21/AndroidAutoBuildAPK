<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AndroidAutoBuildAPK" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/hokm_green_200</item>
        <item name="colorPrimaryVariant">@color/hokm_green_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/hokm_gold_500</item>
        <item name="colorSecondaryVariant">@color/hokm_green_500</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>

    <style name="HokmRowStyle"><item name="android:layout_width">match_parent</item><item name="android:layout_height">wrap_content</item><item name="android:layout_marginTop">12dp</item><item name="android:background">@drawable/bg_panel_light</item><item name="android:gravity">center_vertical</item><item name="android:minHeight">88dp</item><item name="android:orientation">horizontal</item><item name="android:padding">12dp</item><item name="android:clickable">true</item><item name="android:focusable">true</item></style>
    <style name="HokmRowIconStyle"><item name="android:layout_width">54dp</item><item name="android:layout_height">54dp</item><item name="android:background">@drawable/bg_icon_circle</item><item name="android:gravity">center</item><item name="android:textColor">@color/white</item><item name="android:textSize">24sp</item></style>
    <style name="HokmRowTextColStyle"><item name="android:layout_width">0dp</item><item name="android:layout_height">wrap_content</item><item name="android:layout_marginStart">12dp</item><item name="android:layout_weight">1</item><item name="android:orientation">vertical</item></style>
    <style name="HokmRowTitleStyle"><item name="android:textColor">#0E2A17</item><item name="android:textSize">28sp</item><item name="android:textStyle">bold</item></style>
    <style name="HokmRowSubtitleStyle"><item name="android:textColor">#263a2a</item><item name="android:textSize">14sp</item></style>
    <style name="HokmRowArrowStyle"><item name="android:layout_width">24dp</item><item name="android:layout_height">wrap_content</item><item name="android:gravity">center</item><item name="android:textColor">#0E2A17</item><item name="android:textSize">38sp</item></style>
</resources>
